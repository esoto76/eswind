{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared": ["./src/shared/index.ts"],
      "@shared/*": ["./src/shared/*"],
      "@theme": ["./src/theme/index.ts"],
      "@theme/*": ["./src/theme/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "rollup.config.js"]
}
